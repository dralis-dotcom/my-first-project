# Copy this file to .env and fill in your values

# Firebase — get these from your Firebase project settings
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Telegram and the admin PIN are no longer configured here.
# Each household sets its own Telegram bot in the app's Settings screen,
# and owner access is protected by Firebase Auth (email + password).
